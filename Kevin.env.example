# ============================================
# Kevin's TradingAgents -- API Keys Template
# Copy this file to .env and fill in real keys
# ============================================

# IMPORTANT: API CREDIT vs SUBSCRIPTION
# -----------------------------------------------
# TradingAgents calls the Anthropic API directly.
# This is SEPARATE from your claude.ai subscription --
# you need API credits at platform.anthropic.com/settings/billing
#
# Each full analysis costs roughly $0.30-$1.00 depending on
# research depth and number of analysts selected.
# If credit runs out mid-run, the analysis will crash.
# run_safe.bat will detect the crash and save any partial output.
#
# SWITCHING PROVIDERS when Anthropic credit is low:
#
#   Option A -- OpenAI (reliable, similar cost):
#     TRADINGAGENTS_LLM_PROVIDER=openai
#     TRADINGAGENTS_DEEP_THINK_LLM=gpt-4o
#     TRADINGAGENTS_QUICK_THINK_LLM=gpt-4o-mini
#
#   Option B -- DeepSeek (much cheaper, ~10x lower cost):
#     TRADINGAGENTS_LLM_PROVIDER=deepseek
#     TRADINGAGENTS_DEEP_THINK_LLM=deepseek-reasoner
#     TRADINGAGENTS_QUICK_THINK_LLM=deepseek-chat
#
# To switch, update the three TRADINGAGENTS_ lines below.
# -----------------------------------------------

ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# Active provider -- change to openai or deepseek if Anthropic credit runs out
TRADINGAGENTS_LLM_PROVIDER=anthropic
TRADINGAGENTS_DEEP_THINK_LLM=claude-sonnet-4-6
TRADINGAGENTS_QUICK_THINK_LLM=claude-haiku-4-5-20251001

# Output in English
TRADINGAGENTS_OUTPUT_LANGUAGE=English
